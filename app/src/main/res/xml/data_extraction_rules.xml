<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- 
        SECURITY: Only allow non-sensitive app data to be backed up.
        Sensitive data (API keys, tokens, SSH keys) must NOT be backed up to Google Cloud.
        -->
        <exclude domain="sharedpref" path="secure_prefs.xml" />
        <exclude domain="database" path="*.db" />
        <include domain="sharedpref" path="settings_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <!-- Device-to-device transfers should also exclude sensitive data -->
        <exclude domain="sharedpref" path="secure_prefs.xml" />
        <exclude domain="database" path="*.db" />
    </device-transfer>
</data-extraction-rules>
