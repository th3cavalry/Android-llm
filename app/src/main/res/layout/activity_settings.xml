<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/settings"
            android:background="?attr/colorPrimary" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Section 1: Inference Backend (expanded by default) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerBackend"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/section_inference_backend"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorPrimary" />

                        <ImageView
                            android:id="@+id/chevronBackend"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/arrow_up_float"
                            android:contentDescription="@string/collapse"
                            android:tint="?attr/colorPrimary" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/bodyBackend"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="16dp">

                        <RadioGroup
                            android:id="@+id/rgBackend"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp">

                            <RadioButton
                                android:id="@+id/rbRemote"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/backend_remote"
                                android:padding="4dp" />

                            <RadioButton
                                android:id="@+id/rbMediaPipe"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/backend_mediapipe"
                                android:padding="4dp" />

                            <RadioButton
                                android:id="@+id/rbLiteRtLm"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/backend_litert_lm"
                                android:padding="4dp" />

                            <RadioButton
                                android:id="@+id/rbOllamaLocal"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/backend_ollama_local"
                                android:padding="4dp" />

                            <RadioButton
                                android:id="@+id/rbGeminiNano"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/backend_gemini_nano"
                                android:padding="4dp" />

                        </RadioGroup>

                        <LinearLayout
                            android:id="@+id/layoutMediaPipeModel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/mediapipe_model_path"
                                android:layout_marginBottom="8dp"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etModelPath"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="textUri"
                                    android:singleLine="true" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <Button
                                android:id="@+id/btnBrowseModel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/browse_model"
                                android:layout_marginBottom="4dp"
                                style="@style/Widget.Material3.Button.TonalButton" />

                            <Button
                                android:id="@+id/btnBrowseModelCatalog"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/browse_model_catalog"
                                android:layout_marginBottom="4dp"
                                style="@style/Widget.Material3.Button.OutlinedButton" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/mediapipe_model_hint"
                                android:textSize="12sp"
                                android:textColor="?android:attr/textColorSecondary"
                                android:layout_marginBottom="12dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layoutLiteRtLmModel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/litert_lm_model_path"
                                android:layout_marginBottom="8dp"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etLiteRtLmModelPath"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="textUri"
                                    android:singleLine="true" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <Button
                                android:id="@+id/btnBrowseLiteRtLmModel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/browse_model"
                                android:layout_marginBottom="4dp"
                                style="@style/Widget.Material3.Button.TonalButton" />

                            <Button
                                android:id="@+id/btnBrowseLiteRtLmCatalog"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/browse_model_catalog"
                                android:layout_marginBottom="4dp"
                                style="@style/Widget.Material3.Button.OutlinedButton" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/litert_lm_model_hint"
                                android:textSize="12sp"
                                android:textColor="?android:attr/textColorSecondary"
                                android:layout_marginBottom="12dp" />
                        </LinearLayout>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardOllamaInfo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:visibility="gone"
                            app:cardElevation="0dp"
                            app:strokeColor="?attr/colorPrimary"
                            app:strokeWidth="1dp"
                            app:cardCornerRadius="8dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/ollama_local_hint"
                                android:textSize="12sp"
                                android:padding="12dp"
                                android:textColor="?android:attr/textColorSecondary" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardGeminiNanoInfo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:visibility="gone"
                            app:cardElevation="0dp"
                            app:strokeColor="?attr/colorPrimary"
                            app:strokeWidth="1dp"
                            app:cardCornerRadius="8dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/gemini_nano_hint"
                                android:textSize="12sp"
                                android:padding="12dp"
                                android:textColor="?android:attr/textColorSecondary" />
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section 2: Chat Appearance -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerAppearance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/section_chat_appearance"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorPrimary" />

                        <ImageView
                            android:id="@+id/chevronAppearance"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/arrow_down_float"
                            android:contentDescription="@string/expand"
                            android:tint="?attr/colorPrimary" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/bodyAppearance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="16dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/color_theme_label"
                            android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:layout_marginBottom="4dp" />

                        <Spinner
                            android:id="@+id/spinnerColorTheme"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:entries="@array/color_themes"
                            android:layout_marginBottom="16dp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchHideToolMessages"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/hide_tool_messages"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/hide_tool_messages_hint"
                            android:textSize="12sp"
                            android:textColor="?android:attr/textColorSecondary"
                            android:layout_marginBottom="8dp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchShowResponseInfo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/show_response_info"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/show_response_info_hint"
                            android:textSize="12sp"
                            android:textColor="?android:attr/textColorSecondary" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section 3: System Prompt -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerSystemPrompt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/section_system_prompt"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorPrimary" />

                        <ImageView
                            android:id="@+id/chevronSystemPrompt"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/arrow_down_float"
                            android:contentDescription="@string/expand"
                            android:tint="?attr/colorPrimary" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/bodySystemPrompt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="16dp"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/system_prompt_hint"
                            android:layout_marginBottom="4dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etSystemPrompt"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textMultiLine|textCapSentences"
                                android:minLines="3"
                                android:maxLines="8"
                                android:gravity="top|start" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/system_prompt_description"
                            android:textSize="12sp"
                            android:textColor="?android:attr/textColorSecondary" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section 4: LLM / Cloud API -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerLlm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/section_llm"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorPrimary" />

                        <ImageView
                            android:id="@+id/chevronLlm"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/arrow_down_float"
                            android:contentDescription="@string/expand"
                            android:tint="?attr/colorPrimary" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/bodyLlm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="16dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/section_cloud_presets"
                            android:textAppearance="?attr/textAppearanceLabelMedium"
                            android:layout_marginBottom="4dp" />

                        <Spinner
                            android:id="@+id/spinnerCloudProvider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:entries="@array/cloud_providers"
                            android:layout_marginBottom="12dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/llm_endpoint"
                            android:layout_marginBottom="12dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etLlmEndpoint"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textUri"
                                android:imeOptions="actionNext" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/llm_api_key"
                            android:layout_marginBottom="12dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            app:endIconMode="password_toggle">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etLlmApiKey"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPassword"
                                android:imeOptions="actionNext" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/llm_model"
                            android:layout_marginBottom="4dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etLlmModel"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:imeOptions="actionNext" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp"
                            android:gravity="center_vertical">

                            <Button
                                android:id="@+id/btnFetchModels"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/fetch_models"
                                style="@style/Widget.Material3.Button.TonalButton" />

                            <Spinner
                                android:id="@+id/spinnerRemoteModels"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="8dp"
                                android:visibility="gone" />
                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/max_tokens"
                            android:layout_marginBottom="12dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMaxTokens"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:imeOptions="actionDone" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:id="@+id/tvTemperature"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Temperature: 0.7"
                            android:layout_marginBottom="4dp" />

                        <SeekBar
                            android:id="@+id/seekTemperature"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:max="20"
                            android:progress="7" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section 5: Hugging Face -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerHf"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/section_hf"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorPrimary" />

                        <ImageView
                            android:id="@+id/chevronHf"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/arrow_down_float"
                            android:contentDescription="@string/expand"
                            android:tint="?attr/colorPrimary" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/bodyHf"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="16dp"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hf_token"
                            android:layout_marginBottom="4dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            app:endIconMode="password_toggle">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etHfToken"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPassword" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/hf_token_hint"
                            android:textSize="12sp"
                            android:textColor="?android:attr/textColorSecondary" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section 6: Web Search -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/section_search"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorPrimary" />

                        <ImageView
                            android:id="@+id/chevronSearch"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/arrow_down_float"
                            android:contentDescription="@string/expand"
                            android:tint="?attr/colorPrimary" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/bodySearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="16dp"
                        android:visibility="gone">

                        <Spinner
                            android:id="@+id/spinnerSearchProvider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:entries="@array/search_providers"
                            android:layout_marginBottom="12dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/search_api_key"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            app:endIconMode="password_toggle">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etSearchApiKey"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPassword" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section 7: GitHub -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerGithub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/section_github"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorPrimary" />

                        <ImageView
                            android:id="@+id/chevronGithub"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/arrow_down_float"
                            android:contentDescription="@string/expand"
                            android:tint="?attr/colorPrimary" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/bodyGithub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="16dp"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/github_token"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            app:endIconMode="password_toggle">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etGithubToken"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPassword" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section 8: SSH -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerSsh"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/section_ssh"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorPrimary" />

                        <ImageView
                            android:id="@+id/chevronSsh"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/arrow_down_float"
                            android:contentDescription="@string/expand"
                            android:tint="?attr/colorPrimary" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/bodySsh"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="16dp"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/ssh_default_host"
                            android:layout_marginBottom="12dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etSshDefaultHost"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textUri"
                                android:imeOptions="actionNext" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/ssh_default_user"
                            android:layout_marginBottom="12dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etSshDefaultUser"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:imeOptions="actionNext" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/ssh_private_key"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etSshPrivateKey"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textMultiLine"
                                android:minLines="4"
                                android:gravity="top" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
